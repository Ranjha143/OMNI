        function extractErrorMessage(rawError) {

            if (!rawError)
                return "";

            // Case 3: If it's already not JSON, return as plain text
            if (typeof rawError !== "string")
                rawError = JSON.stringify(rawError);

            try {
                let parsed = JSON.parse(rawError);

                // Case 2: Direct array
                if (Array.isArray(parsed)) {
                    return parsed[0]?.errormsg || rawError;
                }

                // Case 1: Object with "errors" property (stringified array)
                if (parsed.errors) {
                    let nestedErrors = JSON.parse(parsed.errors);
                    return nestedErrors[0]?.errormsg || rawError;
                }

                return rawError;

            } catch (e) {
                // Case 3: Plain text (not JSON)
                return rawError;
            }
        }



